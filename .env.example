NEXT_PUBLIC_ENABLE_AUTH=false
NEXT_PUBLIC_ENABLE_CLOUD_SYNC=false
NEXT_PUBLIC_ENABLE_ENHANCED_IMPORT=false
NEXT_PUBLIC_PROVIDER_HEALTH_TIMEOUT_MS=5000
PROVIDER_HEALTH_TIMEOUT_MS=5000

# 服务端私有 provider 配置
# 优先读取下面这组变量；如果未配置，系统才会回退到 NEXT_PUBLIC_*。

# 真实账号登录服务地址
# 例如：https://your-auth-service.example.com
AUTH_PROVIDER_URL=
AUTH_PROVIDER_HEALTH_PATH=/health
AUTH_PROVIDER_AUTH_HEADER_NAME=Authorization
AUTH_PROVIDER_AUTH_HEADER_VALUE=

# 前端公开回退配置（仅在没有服务端私有配置时使用）
NEXT_PUBLIC_AUTH_PROVIDER_URL=
NEXT_PUBLIC_AUTH_PROVIDER_HEALTH_PATH=/health

# 真实云端项目存储服务地址
# 例如：https://your-cloud-storage.example.com
CLOUD_STORAGE_PROVIDER_URL=
CLOUD_STORAGE_PROVIDER_HEALTH_PATH=/health
CLOUD_STORAGE_PROVIDER_AUTH_HEADER_NAME=Authorization
CLOUD_STORAGE_PROVIDER_AUTH_HEADER_VALUE=

# 前端公开回退配置（仅在没有服务端私有配置时使用）
NEXT_PUBLIC_CLOUD_STORAGE_PROVIDER_URL=
NEXT_PUBLIC_CLOUD_STORAGE_PROVIDER_HEALTH_PATH=/health

# 真实 OCR 服务地址
# 例如：https://your-ocr-service.example.com
OCR_PROVIDER_URL=
OCR_PROVIDER_HEALTH_PATH=/health
OCR_PROVIDER_AUTH_HEADER_NAME=Authorization
OCR_PROVIDER_AUTH_HEADER_VALUE=

# 前端公开回退配置（仅在没有服务端私有配置时使用）
NEXT_PUBLIC_OCR_PROVIDER_URL=
NEXT_PUBLIC_OCR_PROVIDER_HEALTH_PATH=/health

# 真实视频增强服务地址
# 例如：https://your-video-service.example.com
VIDEO_ENHANCEMENT_PROVIDER_URL=
VIDEO_ENHANCEMENT_PROVIDER_HEALTH_PATH=/health
VIDEO_ENHANCEMENT_PROVIDER_AUTH_HEADER_NAME=Authorization
VIDEO_ENHANCEMENT_PROVIDER_AUTH_HEADER_VALUE=

# 前端公开回退配置（仅在没有服务端私有配置时使用）
NEXT_PUBLIC_VIDEO_ENHANCEMENT_PROVIDER_URL=
NEXT_PUBLIC_VIDEO_ENHANCEMENT_PROVIDER_HEALTH_PATH=/health
